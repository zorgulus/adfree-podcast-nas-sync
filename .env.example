# --- MinusPod ad-detection LLM ---
# Any OpenAI-compatible endpoint works: a local LM Studio / Ollama server, or
# a cloud provider. See README "Choosing an LLM" for free/local model picks.
LLM_PROVIDER=openai-compatible
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_API_KEY=not-needed
OPENAI_MODEL=qwen/qwen3-30b-a3b-2507

WHISPER_MODEL=base
WHISPER_DEVICE=cpu
OMP_NUM_THREADS=12

BASE_URL=http://localhost:8000
MINUSPOD_PORT=8000
MAX_AUDIO_DOWNLOAD_MB=800

# Raised from MinusPod's default of 3s - see README "Known gotchas": the
# default is low enough that real speech near an episode's end can get cut
# along with a genuine ad if Whisper failed to transcribe the last few
# seconds cleanly.
VAD_GAP_TAIL_MIN_SECONDS=20

# --- sync_to_nas.py / podcasts-api destination ---
FEED_SLUG=my-podcast
NAS_HOST=192.168.1.x
NAS_PODCASTS_PATH=/path/on/your/nas/Podcasts
# Public URL your devices use to reach NAS_PODCASTS_PATH - a Tailscale HTTPS
# hostname is a good, free option (see README "Security").
PUBLIC_BASE_ROOT=https://your-tailscale-hostname.ts.net/podcasts
